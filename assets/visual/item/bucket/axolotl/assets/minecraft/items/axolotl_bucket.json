            {
              "when": "lucy",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/axolotl_bucket/_unset/lucy"
              }
            },
            {
              "when": "wild",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/axolotl_bucket/_unset/wild"
              }
            },
            {
