              }
            }
          ],
          "fallback": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/_unset/_fallback"
          }
        },
        "on_false": {
          "type": "minecraft:condition",
          "property": "minecraft:extended_view",
          "on_true": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/_unset/_unset_extended"
          },
          "on_false": {
