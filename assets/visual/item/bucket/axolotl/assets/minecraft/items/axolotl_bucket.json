{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:has_component",
    "component": "minecraft:bucket_entity_data",
    "ignore_default": true,
    "on_true": {
      "type": "minecraft:condition",
      "property": "minecraft:has_component",
      "component": "minecraft:axolotl/variant",
      "on_true": {
        "type": "minecraft:select",
        "property": "minecraft:component",
        "component": "minecraft:axolotl/variant",
        "cases": [
          {
            "when": "lucy",
            "model": {
              "type": "minecraft:model",
              "model": "minecraft:item/axolotl_bucket/_fallback/lucy"
            }
          },
          {
            "when": "wild",
            "model": {
              "type": "minecraft:model",
              "model": "minecraft:item/axolotl_bucket/_fallback/wild"
            }
          },
          {
            "when": "gold",
            "model": {
              "type": "minecraft:model",
              "model": "minecraft:item/axolotl_bucket/_fallback/gold"
            }
          },
          {
            "when": "cyan",
            "model": {
              "type": "minecraft:model",
              "model": "minecraft:item/axolotl_bucket/_fallback/cyan"
            }
          },
          {
            "when": "blue",
            "model": {
              "type": "minecraft:model",
              "model": "minecraft:item/axolotl_bucket/_fallback/blue"
            }
          }
        ],
        "fallback": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_bucket/_fallback/_fallback"
        }
      },
      "on_false": {
        "type": "minecraft:condition",
        "property": "minecraft:extended_view",
        "on_true": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_bucket/_fallback/_unset_extended"
        },
        "on_false": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_bucket/_fallback/_unset"
        }
      }
    },
    "on_false": {
      "type": "minecraft:condition",
      "property": "minecraft:extended_view",
      "on_true": {
        "type": "minecraft:condition",
        "property": "minecraft:has_component",
        "component": "minecraft:axolotl/variant",
