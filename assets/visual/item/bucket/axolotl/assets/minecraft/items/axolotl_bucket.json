            {
              "when": "gold",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/axolotl_bucket/_unset_extended/gold"
              }
            },
            {
              "when": "cyan",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/axolotl_bucket/_unset_extended/cyan"
              }
            },
            {
              "when": "blue",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/axolotl_bucket/_unset_extended/blue"
              }
            }
          ],
          "fallback": {
            "type": "minecraft:model",
