{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:fox/variant",
    "cases": [
      {
        "when": "red",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/fox_spawn_egg/red"
        }
      },
      {
        "when": "snow",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/fox_spawn_egg/snowy"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:extended_view",
      "on_true": {
        "type": "minecraft:model",
        "model": "minecraft:item/fox_spawn_egg_extended"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "minecraft:item/fox_spawn_egg"
      }
    }
  }
}
