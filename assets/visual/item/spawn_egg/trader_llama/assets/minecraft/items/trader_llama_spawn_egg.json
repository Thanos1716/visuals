{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:llama/variant",
    "cases": [
      {
        "when": "creamy",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/trader_llama_spawn_egg/creamy"
        }
      },
      {
        "when": "white",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/trader_llama_spawn_egg/white"
        }
      },
      {
        "when": "brown",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/trader_llama_spawn_egg/brown"
        }
      },
      {
        "when": "gray",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/trader_llama_spawn_egg/gray"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:extended_view",
      "on_true": {
        "type": "minecraft:model",
        "model": "minecraft:item/trader_llama_spawn_egg_extended"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "minecraft:item/trader_llama_spawn_egg"
      }
    }
  }
}
