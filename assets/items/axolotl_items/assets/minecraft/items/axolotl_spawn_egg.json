{
  "model": {
    "type": "minecraft:select",
    "cases": [
      {
        "when": "lucy",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_spawn_egg/lucy"
        }
      },
      {
        "when": "wild",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_spawn_egg/wild"
        }
      },
      {
        "when": "gold",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_spawn_egg/gold"
        }
      },
      {
        "when": "cyan",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_spawn_egg/cyan"
        }
      },
      {
        "when": "blue",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/axolotl_spawn_egg/blue"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:extended_view",
      "on_true": {
        "type": "minecraft:model",
        "model": "minecraft:item/axolotl_spawn_egg_extended"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "minecraft:item/axolotl_spawn_egg"
      }
    },
    "property": "minecraft:component",
    "component": "minecraft:axolotl/variant"
  }
}
