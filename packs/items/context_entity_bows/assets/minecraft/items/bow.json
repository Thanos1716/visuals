{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:context_entity_type",
    "cases": [
      {
        "when": "minecraft:bogged",
        "model": {
          "type": "minecraft:condition",
          "on_false": {
            "type": "minecraft:model",
            "model": "minecraft:item/bow/bogged"
          },
          "on_true": {
            "type": "minecraft:range_dispatch",
            "entries": [
              {
                "model": {
                  "type": "minecraft:model",
                  "model": "minecraft:item/bow/bogged/pulling_1"
                },
                "threshold": 0.65
              },
              {
                "model": {
                  "type": "minecraft:model",
                  "model": "minecraft:item/bow/bogged/pulling_2"
                },
                "threshold": 0.9
              }
            ],
            "fallback": {
              "type": "minecraft:model",
              "model": "minecraft:item/bow/bogged/pulling_0"
            },
            "property": "minecraft:use_duration",
            "scale": 0.05
          },
          "property": "minecraft:using_item"
        }
      },
      {
        "when": "minecraft:stray",
