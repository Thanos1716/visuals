{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:pig/variant",
    "cases": [
      {
        "when": "minecraft:cold",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/pig_spawn_egg/cold"
        }
      },
      {
        "when": "minecraft:temperate",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/pig_spawn_egg/temperate"
        }
      },
      {
        "when": "minecraft:warm",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/pig_spawn_egg/warm"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:extended_view",
      "on_true": {
        "type": "minecraft:model",
        "model": "minecraft:item/pig_spawn_egg_extended"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "minecraft:item/pig_spawn_egg"
      }
    }
  }
}
