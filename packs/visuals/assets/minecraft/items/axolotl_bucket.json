{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:has_component",
    "component": "minecraft:bucket_entity_data",
    "ignore_default": true,
    "on_true": {
      "type": "minecraft:select",
      "property": "minecraft:component",
      "component": "minecraft:axolotl/variant",
      "cases": [
        {
          "when": "lucy",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/adult/lucy"
          }
        },
        {
          "when": "wild",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/adult/wild"
          }
        },
        {
          "when": "gold",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/adult/gold"
          }
        },
        {
          "when": "cyan",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/adult/cyan"
          }
        },
        {
          "when": "blue",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/adult/blue"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "minecraft:item/axolotl_bucket/adult"
      }
    },
    "on_false": {
      "type": "minecraft:select",
      "property": "minecraft:component",
      "component": "minecraft:axolotl/variant",
      "cases": [
        {
          "when": "lucy",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/spawn_egg/lucy"
          }
        },
        {
          "when": "wild",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/spawn_egg/wild"
          }
        },
        {
          "when": "gold",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/spawn_egg/gold"
          }
        },
        {
          "when": "cyan",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/spawn_egg/cyan"
          }
        },
        {
          "when": "blue",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/axolotl_bucket/spawn_egg/blue"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "minecraft:item/axolotl_bucket/spawn_egg"
      }
    }
  }
}
